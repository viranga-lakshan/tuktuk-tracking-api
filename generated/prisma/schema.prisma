// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  // Project-local output so the app never loads a stale client from a global or wrong @prisma/client cache.
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Role values (app-enforced): SUPER_ADMIN, PROVINCE_ADMIN, DISTRICT_ADMIN, STATION_ADMIN, POLICE
// Stored as TEXT to avoid Prisma 7 client enum deserialization issues with driver adapters.
model User {
  id         Int            @id @default(autoincrement())
  name       String
  email      String         @unique
  password   String
  role       String         @default("POLICE")
  provinceId Int?
  province   Province?      @relation(fields: [provinceId], references: [id])
  districtId Int?
  district   District?      @relation(fields: [districtId], references: [id])
  stationId  Int?
  station    PoliceStation? @relation(fields: [stationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provinceId])
  @@index([districtId])
  @@index([stationId])
}

model Province {
  id        Int        @id @default(autoincrement())
  name      String
  districts District[]
  users     User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model District {
  id             Int             @id @default(autoincrement())
  name           String
  provinceId     Int
  province       Province        @relation(fields: [provinceId], references: [id])
  users          User[]
  policeStations PoliceStation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([provinceId])
}

model PoliceStation {
  id         Int      @id @default(autoincrement())
  name       String
  address    String?
  districtId Int
  district   District @relation(fields: [districtId], references: [id])
  tukTuks    TukTuk[]
  users      User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([districtId])
}

model TukTuk {
  id                 Int           @id @default(autoincrement())
  registrationNumber String        @unique
  name               String?
  policeStationId    Int
  policeStation      PoliceStation @relation(fields: [policeStationId], references: [id])
  locations          Location[]
  devices            Device[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policeStationId])
}

model Device {
  id         Int       @id @default(autoincrement())
  name       String
  keyId      String    @unique
  secretHash String
  tukTukId   Int
  tukTuk     TukTuk    @relation(fields: [tukTukId], references: [id])
  isRevoked  Boolean   @default(false)
  rotatedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([keyId])
  @@index([tukTukId])
}

model Location {
  id         Int      @id @default(autoincrement())
  tukTukId   Int
  tukTuk     TukTuk   @relation(fields: [tukTukId], references: [id])
  latitude   Float
  longitude  Float
  recordedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tukTukId])
  @@index([recordedAt])
  @@index([tukTukId, recordedAt])
}
