# ============================================================
# REQUIRED in all environments
# ============================================================

# PostgreSQL connection string
# For Neon: postgresql://user:password@ep-host.neon.tech/database?sslmode=verify-full
# For local: postgresql://user:password@localhost:5432/database
DATABASE_URL="postgresql://USER:PASSWORD@ep-your-neon-host.neon.tech/neondb?sslmode=require"

# JWT Secret for signing authentication tokens
# ⚠️  CRITICAL: Generate a strong random secret using:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Do NOT use the placeholder below in production
JWT_SECRET="your-super-secret-key-change-this-in-production"

# ============================================================
# OPTIONAL configuration (sensible defaults provided)
# ============================================================

# JWT token expiration (default: 7d)
JWT_EXPIRES_IN=7d

# Server port (default: 3000)
PORT=3000

# Environment type (default: development)
# Use: development, staging, production
NODE_ENV=development
